<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.icet.controller.MainController"
            prefWidth="1200.0" prefHeight="700.0"
            style="-fx-background-color: #ecf0f1;">

    <!-- Left Side Navigation -->
    <left>
        <VBox spacing="10.0" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <VBox.margin>
                <Insets />
            </VBox.margin>
            
            <!-- Logo/Title -->
            <Label text="Pharmacy IMS" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;">
                <padding>
                    <Insets bottom="20.0" />
                </padding>
            </Label>
            
            <!-- Navigation Buttons -->
            <Button fx:id="btnDashboard" text="Dashboard" onAction="#loadDashboard"
                    prefWidth="180.0" prefHeight="45.0"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;">
                <font>
                    <Font size="14.0" />
                </font>
            </Button>
            
            <Button fx:id="btnMedicines" text="Medicines" onAction="#loadMedicines"
                    prefWidth="180.0" prefHeight="45.0"
                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;">
                <font>
                    <Font size="14.0" />
                </font>
            </Button>
            
            <Button fx:id="btnSuppliers" text="Suppliers" onAction="#loadSuppliers"
                    prefWidth="180.0" prefHeight="45.0"
                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;">
                <font>
                    <Font size="14.0" />
                </font>
            </Button>
            
            <Button fx:id="btnSales" text="Sales" onAction="#loadSales"
                    prefWidth="180.0" prefHeight="45.0"
                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;">
                <font>
                    <Font size="14.0" />
                </font>
            </Button>
        </VBox>
    </left>

    <!-- Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: white;">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
            </padding>
        </StackPane>
    </center>

</BorderPane>

