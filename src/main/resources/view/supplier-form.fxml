<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.icet.controller.SupplierFormController"
      spacing="15.0" style="-fx-background-color: white; -fx-padding: 20;">
    
    <Label text="Supplier Form" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
    
    <GridPane hgap="10.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="120.0" />
            <ColumnConstraints minWidth="250.0" />
        </columnConstraints>
        
        <Label text="Name:*" GridPane.rowIndex="0" />
        <TextField fx:id="txtName" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        
        <Label text="Contact Person:" GridPane.rowIndex="1" />
        <TextField fx:id="txtContactPerson" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        
        <Label text="Phone:*" GridPane.rowIndex="2" />
        <TextField fx:id="txtPhone" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        
        <Label text="Email:" GridPane.rowIndex="3" />
        <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        
        <Label text="Address:" GridPane.rowIndex="4" />
        <TextArea fx:id="txtAddress" GridPane.columnIndex="1" GridPane.rowIndex="4"
                  prefRowCount="3" wrapText="true" />
    </GridPane>
    
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button fx:id="btnSave" text="Save" style="-fx-background-color: #27ae60; -fx-text-fill: white;" />
        <Button fx:id="btnCancel" text="Cancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" />
    </HBox>
    
</VBox>
